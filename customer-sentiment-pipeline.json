      "name": "Message a model",
      "credentials": {
        "openAiApi": {
          "id": "d7nD1jMoUG2UPCvO",
          "name": "OpenAI account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const newItems = [];\n\nfor (const item of $input.all()) {\n  let aiResponse = item.json.output[0].content[0].text;\n  aiResponse = aiResponse.replace(/```json|```/g, '').trim();\n  const parsedAI = JSON.parse(aiResponse);\n\n  const originalData = $('Webhook').first().json.body;\n\n\n  newItems.push({\n    json: {\n      customer_name: originalData.customer_name,\n      raw_review: originalData.review_text,\n      sentiment: parsedAI.sentiment,\n      confidence: parseFloat(parsedAI.confidence),\n      category: parsedAI.category\n    }\n  });\n}\n\n\nreturn newItems;\n"
      },
