          "values": [
            {
              "role": "system",
              "content": "Anda adalah AI analisis sentimen teks untuk tim produk.\nTugas Anda adalah menganalisis teks ulasan pelanggan yang diberikan.\nAnda WAJIB mengembalikan output dalam format JSON murni tanpa markdown, tanpa penjelasan, dengan struktur seperti ini:\n{\n  \"sentiment\": \"Positive\" atau \"Neutral\" atau \"Negative\",\n  \"confidence\": angka float antara 0.0 sampai 1.0,\n  \"category\": \"Product_Bug\" atau \"Pricing\" atau \"Customer_Service\" atau \"UI_UX\"\n}\n"
            },
            {
              "content": "=Teks ulasan: {{ $json.body.review_text }}\n"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
